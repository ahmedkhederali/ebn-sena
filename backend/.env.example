# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ibn-sina-dev

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Store the key content as a single line with \n replacing actual newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-byte hex string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Email (dev: use Mailtrap https://mailtrap.io) ────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
EMAIL_FROM=noreply@ibnsina.sa

# ─── SMS ──────────────────────────────────────────────────────────────────────
# Use "mock" in dev — logs message instead of calling Unifonic
SMS_PROVIDER=mock
UNIFONIC_APP_SID=your-unifonic-sid

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── HyperPay (sandbox) ───────────────────────────────────────────────────────
HYPERPAY_ACCESS_TOKEN=your-sandbox-token
HYPERPAY_BASE_URL=https://eu-test.oppwa.com
HYPERPAY_ENTITY_ID_VISA=your-entity-id
HYPERPAY_WEBHOOK_SECRET=your-webhook-hmac-secret

# ─── Stripe (sandbox) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
